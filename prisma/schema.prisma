generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Roletype {
  DOCTOR
  USER
}

model Docter {
  id             Int         @id @default(autoincrement())
  username       String      @unique
  password       String
  specialization String
  doctorNote     DoctorNote? @relation(fields: [doctorNoteId], references: [id])
  doctorNoteId   Int?
  role           Roletype    @default(DOCTOR)
}

model User {
  id             Int           @id @default(autoincrement())
  username       String        @unique
  password       String
  doctorNote     DoctorNote?   @relation(fields: [doctorNoteId], references: [id])
  doctorNoteId   Int?
  healthRecord   HealthRecord? @relation(fields: [healthRecordId], references: [id])
  healthRecordId Int?
  role           Roletype      @default(USER)
}

model DoctorNote {
  id       Int      @id @default(autoincrement())
  Doctorid Docter[]
  userid   User[]
  note     String
  createAt DateTime @default(now())
}

model HealthRecord {
  id     Int      @id @default(autoincrement())
  userid User[]
  type   String
  value  String
  date   DateTime @default(now())
}
